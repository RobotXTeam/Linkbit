{
  "name": "@linkbit/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Linkbit visual desktop client",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.linkbit.client",
    "productName": "Linkbit",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../bin",
        "to": "bin",
        "filter": [
          "linkbit-agent*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    }
  }
}
