<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.linkbit.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/linkbit/linkbit-agent</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>LINKBIT_WG_DRY_RUN</key>
    <string>false</string>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/var/log/linkbit-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/linkbit-agent.err</string>
</dict>
</plist>
