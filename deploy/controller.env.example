# Use :8080 behind a reverse proxy, or :80 for a direct single-server install.
LINKBIT_LISTEN_ADDR=:8080
LINKBIT_PUBLIC_URL=https://controller.example.com
LINKBIT_DATABASE_PATH=/var/lib/linkbit/linkbit.db
LINKBIT_API_KEY_PEPPER=replace-with-random-secret
LINKBIT_BOOTSTRAP_API_KEY=replace-with-bootstrap-admin-key
LINKBIT_WEB_DIR=/opt/linkbit/web
LINKBIT_LOG_LEVEL=info
LINKBIT_HUB_WG_ENABLED=false
LINKBIT_HUB_WG_INTERFACE=linkbit-hub
LINKBIT_HUB_WG_IP=10.88.0.1
LINKBIT_HUB_WG_NETWORK=10.88.0.0/16
LINKBIT_HUB_WG_PORT=41641
LINKBIT_HUB_WG_PRIVATE_KEY=
LINKBIT_HUB_WG_ENDPOINT=controller.example.com:41641
