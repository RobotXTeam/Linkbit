# Controller
LINKBIT_LISTEN_ADDR=:8080
LINKBIT_PUBLIC_URL=https://controller.example.com
LINKBIT_DATABASE_PATH=/var/lib/linkbit/linkbit.db
LINKBIT_API_KEY_PEPPER=replace-with-random-32-byte-secret
LINKBIT_BOOTSTRAP_API_KEY=replace-with-one-time-admin-api-key

# Relay
LINKBIT_CONTROLLER_URL=https://controller.example.com
LINKBIT_API_KEY=replace-with-relay-api-key
LINKBIT_RELAY_ID=relay-ap-1
LINKBIT_RELAY_NAME=linkbit-relay-ap-1
LINKBIT_RELAY_PUBLIC_URL=https://relay.example.com
LINKBIT_RELAY_REGION=ap
LINKBIT_HEARTBEAT_SECONDS=30

# Agent
LINKBIT_ENROLLMENT_KEY=replace-with-device-enrollment-key
LINKBIT_DEVICE_NAME=linkbit-device
LINKBIT_HEALTH_SECONDS=30

